---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import Navbar from "../components/Navbar.astro";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";

type Props = CollectionEntry<"shows">["data"];

const { title, description, showDate, roles, director, company } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body
    class="dark:bg-stone-950 font-inter dark:text-white md:max-w-screen-md md:mx-auto px-4 md:px-1"
  >
    <Navbar />
    <main>
      <article>
        <div class="">
          <div class="">
            <h1 class="text-4xl font-semibold">{title}</h1>
            <div class="text-sm my-2">
              <p>Show Date: <FormattedDate date={showDate} /></p>
              <p>Director: {director}</p>
              <p>Company: {company}</p>
            </div>
            <div class="flex flex-col md:flex-row gap-2">
              {
                roles.map((role) => (
                  <p class="bg-stone-200 dark:bg-stone-700 rounded-md px-1">
                    {role}
                  </p>
                ))
              }
            </div>
          </div>
          <div class="prose prose-stone dark:prose-invert pt-4">
            <slot />
          </div>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
